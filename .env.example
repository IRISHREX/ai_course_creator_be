DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ignouprep
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PORT=5000
JSON_BODY_LIMIT=10mb
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://192.168.56.1:8080,https://ignouprep.lovable.app

# Google Gemini API
GOOGLE_AI_API_KEY=

# Bootstrap super admin (matching email gets admin + super_admin roles on signup)
SUPER_ADMIN_EMAILS=admin@example.com

# Only needed for one-time data migration from Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
