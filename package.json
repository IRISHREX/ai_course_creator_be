{
  "name": "ignouprep-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsx scripts/prisma-auto.ts generate && tsx src/server.ts\"",
    "dev:nodemon": "nodemon --watch src --ext ts --exec \"tsx scripts/prisma-auto.ts generate && tsx src/server.ts\"",
    "dev:mysql": "prisma generate --schema=prisma/schema.prisma && prisma migrate dev --schema=prisma/schema.prisma --name init && tsx watch src/server.ts",
    "dev:postgres": "prisma generate --schema=prisma/schema.postgres.prisma && prisma db push --schema=prisma/schema.postgres.prisma && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:auto": "tsx scripts/prisma-auto.ts generate",
    "prisma:migrate:auto": "tsx scripts/prisma-auto.ts migrate:deploy",
    "prisma:migrate-dev:auto": "tsx scripts/prisma-auto.ts migrate:dev",
    "prisma:push:auto": "tsx scripts/prisma-auto.ts db:push",
    "prisma:generate:mysql": "prisma generate --schema=prisma/schema.prisma",
    "prisma:generate:postgres": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:mysql": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:migrate:postgres": "prisma migrate deploy --schema=prisma/schema.postgres.prisma",
    "prisma:push:postgres": "prisma db push --schema=prisma/schema.postgres.prisma",
    "prisma:dev": "prisma migrate dev",
    "prisma:dev:mysql": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:export": "tsx scripts/export-from-supabase.ts",
    "db:import": "tsx scripts/import-into-prisma.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
